OPENAI_API_KEY=your-api-key
EXA_API_KEY=your-exa-api-key

# SimpleAuth: same token as web VITE_WEAVE_AUTH_TOKEN.
WEAVE_AUTH_TOKEN=replace-with-local-dev-token
WEAVE_AUTH_USER_ID=local-user
WEAVE_AUTH_USER_NAME=Local User
# Optional multi-user map: token -> user. Each id becomes isolated Mastra resourceId.
# WEAVE_AUTH_TOKENS='{"token-a":{"id":"user-a","name":"User A","role":"user"},"token-b":{"id":"user-b","name":"User B","role":"user"}}'

# Persistence: local file by default. Set Turso for remote libSQL.
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-turso-token
