{
  "name": "weave",
  "version": "0.1.0",
  "private": true,
  "description": "Weave repo command index",
  "type": "module",
  "scripts": {
    "dev": "npm --prefix server run dev",
    "build": "npm --prefix server run build",
    "start": "npm --prefix server run start",
    "server:install": "npm --prefix server ci",
    "server:dev": "npm --prefix server run dev",
    "server:build": "npm --prefix server run build",
    "server:start": "npm --prefix server run start",
    "desktop:install": "npm --prefix desktop ci",
    "desktop:dev": "npm --prefix desktop run dev",
    "desktop:package": "npm --prefix desktop run package",
    "desktop:typecheck": "npm --prefix desktop run typecheck",
    "desktop:test": "npm --prefix desktop run test",
    "portal:check": "deno task --config portal/deno.json check",
    "portal:test": "deno task --config portal/deno.json test",
    "portal:login": "deno task --config portal/deno.json login",
    "portal:dev": "deno task --config portal/deno.json dev",
    "portal:build": "deno task --config portal/deno.json build",
    "portal:window-host:smoke": "deno task --config portal/deno.json window-host:smoke",
    "portal:window-host:session-smoke": "deno task --config portal/deno.json window-host:session-smoke",
    "portal:start": "deno task --config portal/deno.json start",
    "portal:status": "deno task --config portal/deno.json status",
    "portal:stop": "deno task --config portal/deno.json stop",
    "web:install": "npm --prefix web ci",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "mobile:install": "npm --prefix mobile ci",
    "mobile:dev": "npm --prefix mobile run dev",
    "mobile:build": "npm --prefix mobile run build",
    "mobile:cap:sync": "npm --prefix mobile run cap:sync",
    "tui:check": "deno task --config tui/deno.json check",
    "tui:start": "deno task --config tui/deno.json start",
    "tui:build": "deno task --config tui/deno.json build"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
