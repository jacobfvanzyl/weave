{
  "tasks": {
    "check": "deno check src/main.ts",
    "native": "deno run --allow-run --allow-env --allow-read scripts/build-native.ts",
    "test": "deno task native && deno test --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-run src/*_test.ts",
    "dev": "deno task native && deno run --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-run src/main.ts daemon",
    "daemon": "deno run --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-run src/main.ts daemon",
    "login": "deno run --allow-net --allow-read --allow-write --allow-env src/main.ts login",
    "build": "deno run --allow-run --allow-env --allow-read --allow-write scripts/build.ts",
    "window-capture:smoke": "node scripts/window-capture-sck-smoke.mjs",
    "window-host:smoke": "node scripts/window-host-smoke.mjs",
    "window-host:session-smoke": "node scripts/window-host-session-smoke.mjs",
    "window-stream-native:smoke": "node scripts/window-stream-native-smoke.mjs",
    "window-stream-native:benchmark": "node scripts/window-stream-native-benchmark.mjs",
    "start": "dist/portal daemon",
    "status": "deno run --allow-net --allow-read --allow-write --allow-env src/main.ts status",
    "stop": "deno run --allow-net --allow-read --allow-write --allow-env src/main.ts stop",
    "install": "deno task build && deno run --allow-read --allow-write --allow-env --allow-run scripts/install.ts"
  },
  "compilerOptions": {
    "lib": ["deno.ns", "deno.window"]
  },
  "fmt": {
    "singleQuote": true,
    "lineWidth": 120
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
