{
  "tasks": {
    "check": "deno check src/main.ts",
    "start": "deno run --allow-net --allow-read --allow-env --allow-run src/main.ts",
    "build": "deno compile --allow-net --allow-read --allow-write --allow-env --allow-run --output dist/weave src/main.ts",
    "install": "deno task build && mkdir -p ~/.local/bin && cp dist/weave ~/.local/bin/weave"
  },
  "nodeModulesDir": "auto",
  "imports": {
    "ai": "npm:ai@6.0.177",
    "cli-highlight": "npm:cli-highlight@2.1.11",
    "pi-tui": "npm:@earendil-works/pi-tui@0.74.0"
  },
  "compilerOptions": {
    "lib": ["deno.ns", "deno.window"]
  },
  "fmt": {
    "singleQuote": true,
    "lineWidth": 120
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
